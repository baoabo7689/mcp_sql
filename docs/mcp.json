{
  "servers": {
    "sql-mcp-server": {
      "command": "node",
      "args": ["D:/Ps/Github/mcp_sql/server.js"],
      "env": {
        "SQL_USER": "sa",
        "SQL_PASSWORD": "your_password",
        "SQL_SERVER": "localhost",
        "SQL_DATABASE": "mydb",
        "SQL_PORT": "1433",
        "SQL_ENCRYPT": "false",
        "SQL_TRUST_SERVER_CERTIFICATE": "true",
      },
    },
  },
}
